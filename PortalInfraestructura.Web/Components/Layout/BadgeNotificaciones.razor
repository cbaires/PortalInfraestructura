@using System.Globalization
@implements IDisposable
@inject NotificacionService Notificacion
@inject ISnackbar Snackbar

<MudBadge Content="@(Notificacion.NotificacionesNoLeidas)"
          Color="Color.Error"
          Overlap="true"
          Visible="@(Notificacion.NotificacionesNoLeidas > 0)"
          Class="mx-2">
    <MudMenu AnchorOrigin="Origin.BottomRight"
             TransformOrigin="Origin.TopRight"
             Icon="@Icons.Material.Filled.Notifications"
             Color="Color.Inherit"
             Dense="true">
        <ChildContent>
            <div style="min-width: 320px; max-width: 360px;">
                <div class="d-flex align-center justify-space-between pa-3 pb-2">
                    <MudText Typo="Typo.h6">Notificaciones</MudText>
                    @if (Notificacion.NotificacionesNoLeidas > 0)
                    {
                        <MudButton Size="Size.Small" OnClick="Notificacion.MarcarTodasComoLeidas" Color="Color.Primary" Variant="Variant.Text">
                            Marcar todas como leídas
                        </MudButton>
                    }
                </div>
                <MudDivider />

                @if (Notificacion.ObtenerNotificaciones(_numeroMaximoNotificacionesMostrar) is var notificaciones && notificaciones.Any())
                {
                    <div style="max-height: 400px; overflow-y: auto;">
                        @foreach (var notificacion in notificaciones)
                        {
                            <MudMenuItem Class="pa-0" OnClick="@(() => Notificacion.MarcarComoLeida(notificacion.Id))">
                                <div class="d-flex align-start pa-3" style="background-color: @(notificacion.Leida ? "transparent" : "rgba(98, 0, 238, 0.08)");">
                                    <MudIcon Icon="@(EstiloNotificacion.ObtenerIcono(notificacion.Tipo))" Color="@EstiloNotificacion.ObtenerColor(notificacion.Tipo)" Class="mr-2" />
                                    <div style="flex: 1; overflow: hidden;">
                                        <div class="d-flex align-center justify-space-between mb-1">
                                            <MudText Typo="Typo.body2" Style="@(notificacion.Leida ? "" : "font-weight: 600;")">
                                                @notificacion.Titulo
                                            </MudText>
                                            @if (!string.IsNullOrEmpty(notificacion.Origen))
                                            {
                                                <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Default" Class="pa-1">
                                                    @notificacion.Origen
                                                </MudChip>
                                            }
                                        </div>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="overflow: hidden; text-overflow: ellipsis;">
                                            @notificacion.Mensaje
                                        </MudText>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary mt-1">
                                            @notificacion.Fecha.ToString("dd/MM/yyyy HH:mm:ss zzz", CultureInfo.InvariantCulture)
                                        </MudText>
                                    </div>
                                </div>
                            </MudMenuItem>
                            <MudDivider />
                        }
                    </div>
                    <MudMenuItem Class="text-center" Href="/notificaciones">
                        <MudText Typo="Typo.body2" Color="Color.Primary">Ver todas</MudText>
                    </MudMenuItem>
                }
                else
                {
                    <div class="pa-4 text-center">
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">Sin notificaciones</MudText>
                    </div>
                }
            </div>
        </ChildContent>
    </MudMenu>
</MudBadge>

@code {
    int _numeroMaximoNotificacionesMostrar = 10;

    protected override void OnInitialized()
    {
        Notificacion.OnNotificacionAgregada += MostrarNotificacion;
        Notificacion.OnNotificacionEliminada += ActualizarEstado;
        Notificacion.OnNotificacionLeida += ActualizarEstado;
        Notificacion.OnTodasNotificacionLeidas += ActualizarEstadoSinParametro;
    }

    private void MostrarNotificacion(Notificacion notificacion)
    {
        InvokeAsync(() =>
        {
            Snackbar.Add(notificacion.Mensaje, EstiloNotificacion.ObtenerSeveridad(notificacion.Tipo));
            StateHasChanged();
        });
    }

    private void ActualizarEstado(Notificacion notificacion)
    {
        InvokeAsync(StateHasChanged);
    }

    private void ActualizarEstadoSinParametro()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Notificacion.OnNotificacionAgregada -= MostrarNotificacion;
        Notificacion.OnNotificacionEliminada -= ActualizarEstado;
        Notificacion.OnNotificacionLeida -= ActualizarEstado;
        Notificacion.OnTodasNotificacionLeidas -= ActualizarEstadoSinParametro;
    }
}

@using Microsoft.AspNetCore.Components.Authorization;
@using PortalInfraestructura.Web.UI.Temas
@inject TemaService temaService;
@inherits LayoutComponentBase;
@implements IDisposable;

<MudThemeProvider IsDarkMode="@(_temaActual == Tema.Oscuro)" Theme="_configuracionTema" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@ToggleDrawer" />
        <div style="display: flex; align-items: center; gap: 12px;">
            <a href="/" style="display: flex; align-items: center; cursor: pointer;">
                <img src="/logo.png" alt="Logo" style="height: 32px; width: auto;" />
            </a>
        </div>
        <MudSpacer />

        @if (_temaActual == Tema.Claro)
        {
            <MudIconButton Icon="@(Icons.Material.Filled.DarkMode)"
                           Color="Color.Inherit"
                           OnClick="async () => await CambiarTemaAsync(Tema.Oscuro)"
                           Title="@("Cambiar a tema oscuro")" />
        }
        @if (_temaActual == Tema.Oscuro)
        {
            <MudIconButton Icon="@(Icons.Material.Filled.LightMode)"
                           Color="Color.Inherit"
                           OnClick="async () => await CambiarTemaAsync(Tema.Claro)"
                           Title="@("Cambiar a tema claro")" />
        }
        <!-- Menú de notificaciones -->
        <div style="display: flex; align-items: center;">
            <BadgeNotificaciones />
        </div>
        <AuthorizeView>
            <Authorized>
                <MenuPerfilUsuario />
            </Authorized>
            <NotAuthorized>
                <MudIconButton Icon="@Icons.Material.Filled.Login" Color="Color.Inherit" Href="/login" />
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="@_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <MudDrawerHeader>
            <MudText Typo="Typo.h6">Portal Infraestructura</MudText>
        </MudDrawerHeader>
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    Se produjo un error inesperado en la aplicación.
    <a href="" class="reload">Recargar</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private bool _drawerOpen = false;
    private Tema _temaActual;
    private MudTheme? _configuracionTema;

    protected override void OnInitialized()
    {
        _configuracionTema = temaService.ConfiguracionTema;
        temaService.OnTemaCambiado += ActualizarTema;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await temaService.InicializarTemaAsync();
        }
    }

    private void ActualizarTema(Tema tema)
    {
        _temaActual = tema;
        StateHasChanged();
    }

    private async Task CambiarTemaAsync(Tema tema)
    {
        await temaService.SeleccionarTema(tema);
    }

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    public void Dispose()
    {
        temaService.OnTemaCambiado -= ActualizarTema;
    }
}
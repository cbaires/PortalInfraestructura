<script type="module" src="@Assets["Components/Layout/ReconnectModal.razor.js"]"></script>

<style>
    #components-reconnect-modal {
    background-color: var(--mud-palette-surface) !important;
    color: var(--mud-palette-text-primary) !important;
    border: 1px solid var(--mud-palette-lines-default);
    border-radius: var(--mud-default-borderradius, 4px);
    box-shadow: var(--mud-elevation-8);
    padding: 20px;
    }

    #components-reconnect-modal::backdrop {
    background-color: var(--mud-palette-overlay-dark);
    }

    #components-reconnect-modal p {
    color: var(--mud-palette-text-primary);
    }

    #components-reconnect-modal button {
    background-color: var(--mud-palette-primary);
    color: var(--mud-palette-primary-text);
    border: none;
    padding: 8px 16px;
    border-radius: var(--mud-default-borderradius, 4px);
    font-weight: 500;
    cursor: pointer;
    margin-top: 10px;
    }

    #components-reconnect-modal button:hover {
    filter: brightness(0.9);
    }
</style>

<dialog id="components-reconnect-modal" data-nosnippet>
    <div class="components-reconnect-container">
        <div class="components-rejoining-animation" aria-hidden="true">
            <div></div>
            <div></div>
        </div>
        <p class="components-reconnect-first-attempt-visible">
            Reconectando con el servidor...
        </p>
        <p class="components-reconnect-repeated-attempt-visible">
            Reconexión fallida... intentando nuevamente en <span id="components-seconds-to-next-attempt"></span> seconds.
        </p>
        <p class="components-reconnect-failed-visible">
            Error al reconectarse.<br />Por favor reintente nuevamente o recargue la página.
        </p>
        <button id="components-reconnect-button" class="components-reconnect-failed-visible">
            Reintentar
        </button>
        <p class="components-pause-visible">
            La sesión ha sido pausada por el servidor.
        </p>
        <p class="components-resume-failed-visible">
            Error al continuar la sesión.<br />Por favor reintente nuevamente o recargue la página.
        </p>
        <button id="components-resume-button" class="components-pause-visible components-resume-failed-visible">
            Continuar
        </button>
    </div>
</dialog>

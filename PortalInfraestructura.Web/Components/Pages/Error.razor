@page "/Error"
@using System.Diagnostics

<PageTitle>Error - PortalInfraestructura</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">
    <MudPaper Class="pa-8" Elevation="4">
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mb-4">
            <MudText Typo="Typo.h4" Class="mb-2">Error</MudText>
            <MudText Typo="Typo.body1">Se produjo un error inesperado en la aplicación.</MudText>
        </MudAlert>

        @if (ShowRequestId)
        {
            <MudDivider Class="my-4" />
            <MudText Typo="Typo.body2" Class="mb-4">
                <strong>Request ID:</strong> <code>@RequestId</code>
            </MudText>
        }

        <MudDivider Class="my-4" />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/" StartIcon="@Icons.Material.Filled.Home">
            Volver al inicio
        </MudButton>
    </MudPaper>
</MudContainer>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    [Inject]
    private ILogger<Error> Logger { get; set; } = default!;

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized()
    {
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;

        Logger.LogError("Error page displayed. Request ID: {RequestId}", RequestId);
    }
}

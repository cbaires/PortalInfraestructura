@page "/notificaciones"
@using PortalInfraestructura.Web.UI.Notificaciones
@using System.Globalization
@implements IDisposable
@inject NotificacionService Notificacion

<PageTitle>Notificaciones - Portal Infraestructura</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudText Typo="Typo.h4" Class="mb-4">Notificaciones</MudText>

    <MudPaper Elevation="2" Class="pa-4">

        <!-- Header -->
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4" Wrap="Wrap.Wrap">
            <MudText Typo="Typo.h6">
                @(_filtroNotificacionesNoLeidasHabilitado
                    ? $"Notificaciones no leídas ({Notificacion.NotificacionesNoLeidas})"
                    : $"Todas las notificaciones ({Notificacion.TodasNotificaciones})")
            </MudText>

            <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                <MudButton Variant="@(!_filtroNotificacionesNoLeidasHabilitado ? Variant.Filled : Variant.Outlined)"
                           Color="Color.Primary"
                           OnClick="@AlternarFiltroNotificacionesNoLeidas"
                           Disabled="@(!_filtroNotificacionesNoLeidasHabilitado)">
                    Todas
                </MudButton>

                <MudButton Variant="@(_filtroNotificacionesNoLeidasHabilitado? Variant.Filled: Variant.Outlined)"
                           Color="Color.Primary"
                           OnClick="@AlternarFiltroNotificacionesNoLeidas"
                           Disabled="@(_filtroNotificacionesNoLeidasHabilitado)">
                    No leídas
                </MudButton>

                @if (Notificacion.NotificacionesNoLeidas > 0)
                {
                    <MudButton Color="Color.Success"
                               Variant="Variant.Filled"
                               StartIcon="@Icons.Material.Filled.DoneAll"
                               OnClick="MarcarTodasComoLeidas">
                        Marcar todas
                    </MudButton>
                }
            </MudStack>
        </MudStack>

        @if ((_filtroNotificacionesNoLeidasHabilitado
                                                        ? Notificacion.ObtenerNotificacionesNoLeidas()
                                                        : Notificacion.ObtenerNotificaciones()) is var notificaciones
                                                        && notificaciones.Any())
        {
            <MudDivider Class="mb-3" />

            <MudStack Spacing="2">
                @foreach (var notificacion in notificaciones)
                {
                    <MudPaper Elevation="1" Class="pa-3" Style="@GetNotificacionStyle(notificacion)">

                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Start">

                            <!-- Icono -->
                            <MudIcon Icon="@EstiloNotificacion.ObtenerIcono(notificacion.Tipo)"
                                     Color="@EstiloNotificacion.ObtenerColor(notificacion.Tipo)"
                                     Size="Size.Large" />

                            <!-- Contenido -->
                            <MudStack Spacing="1" Style="flex:1; min-width:0;">

                                <!-- Header -->
                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                                        <MudText Typo="Typo.h6"
                                                 Style="@(notificacion.Leida ? "" : "font-weight:700")">
                                            @notificacion.Titulo
                                        </MudText>

                                        @if (!notificacion.Leida)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Primary">
                                                Nueva
                                            </MudChip>
                                        }
                                    </MudStack>

                                    @if (!string.IsNullOrEmpty(notificacion.Origen))
                                    {
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                                            @notificacion.Origen
                                        </MudChip>
                                    }
                                </MudStack>

                                <!-- Mensaje -->
                                <MudText Typo="Typo.body1">
                                    @notificacion.Mensaje
                                </MudText>

                                <!-- Footer -->
                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">

                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                        @notificacion.Fecha.ToString("dd/MM/yyyy HH:mm:ss zzz", CultureInfo.InvariantCulture)
                                    </MudText>

                                    <MudStack Row="true" Spacing="1">
                                        @if (!notificacion.Leida)
                                        {
                                            <MudIconButton Icon="@Icons.Material.Filled.Check" aria-label="Marcar como leída" OnClick="@(() => MarcarComoLeida(notificacion.Id))" />
                                        }

                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" aria-label="Borrar" OnClick="@(() => EliminarNotificacion(notificacion.Id))" />
                                    </MudStack>

                                </MudStack>
                            </MudStack>
                        </MudStack>
                    </MudPaper>
                }
            </MudStack>
        }
        else
        {
            <MudStack AlignItems="AlignItems.Center" Class="pa-6">
                <MudText Typo="Typo.h6" Class="mud-text-secondary">
                    Sin notificaciones
                </MudText>
            </MudStack>
        }
    </MudPaper>
</MudContainer>

@code {
    private bool _filtroNotificacionesNoLeidasHabilitado = false;

    protected override void OnInitialized()
    {
        Notificacion.OnNotificacionAgregada += ActualizarNotificaciones;
        Notificacion.OnNotificacionEliminada += ActualizarNotificaciones;
        Notificacion.OnNotificacionLeida += ActualizarNotificaciones;
        Notificacion.OnTodasNotificacionLeidas += ActualizarNotificaciones;
    }

    private void AlternarFiltroNotificacionesNoLeidas()
    {
        _filtroNotificacionesNoLeidasHabilitado = !_filtroNotificacionesNoLeidasHabilitado;
    }

    private void ActualizarNotificaciones(Notificacion? notificacion = null)
    {
        // Se encapsula en InvokeAsync para proteger el hilo de UI
        InvokeAsync(StateHasChanged);
    }

    private void ActualizarNotificaciones()
    {
        ActualizarNotificaciones(null);
    }

    private void MarcarComoLeida(Guid id)
    {
        Notificacion.MarcarComoLeida(id);
    }

    private void MarcarTodasComoLeidas()
    {
        Notificacion.MarcarTodasComoLeidas();
    }

    private void EliminarNotificacion(Guid id)
    {
        Notificacion.Eliminar(id);
    }

    private string GetNotificacionStyle(Notificacion notificacion)
    {
        if (!notificacion.Leida)
        {
            return "border-left: 4px solid var(--mud-palette-primary);";
        }
        return string.Empty;
    }

    public void Dispose()
    {
        Notificacion.OnNotificacionAgregada -= ActualizarNotificaciones;
        Notificacion.OnNotificacionEliminada -= ActualizarNotificaciones;
        Notificacion.OnNotificacionLeida -= ActualizarNotificaciones;
        Notificacion.OnTodasNotificacionLeidas -= ActualizarNotificaciones;
    }
}
